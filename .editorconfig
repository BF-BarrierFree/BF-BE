# 최상위 editorconfig 파일임을 명시합니다.
root = true

# 모든 파일에 적용되는 기본 규칙
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# YAML, JSON, Markdown 파일은 들여쓰기를 2칸으로 합니다.
[*.{yml,yaml,json,md}]
indent_size = 2

# properties 파일은 UTF-8로 읽도록 명시 (한글 깨짐 방지)
[*.properties]
charset = utf-8




     